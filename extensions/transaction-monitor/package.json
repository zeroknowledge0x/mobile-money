{
  "name": "transaction-monitor",
  "displayName": "Transaction Monitor",
  "description": "Monitor local transactions and logs for Mobile Money project",
  "version": "0.1.0",
  "publisher": "devfoma",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "transaction-monitor",
          "title": "Transaction Monitor",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "transaction-monitor": [
        {
          "type": "webview",
          "id": "transaction-monitor.liveLogs",
          "name": "Live Logs",
          "visibility": "visible"
        }
      ]
    },
    "configuration": {
      "title": "Transaction Monitor",
      "properties": {
        "transactionMonitor.backendUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Local backend URL"
        },
        "transactionMonitor.wsUrl": {
          "type": "string",
          "default": "ws://localhost:3000",
          "description": "Local backend WebSocket URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.19.1",
    "@typescript-eslint/eslint-plugin": "^6.19.1"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
