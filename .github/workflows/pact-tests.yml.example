name: Pact Contract Tests

on:
  push:
    branches: [main, develop, feature/*]
  pull_request:
    branches: [main, develop]

jobs:
  pact-tests:
    name: Run Pact Contract Tests
    runs-on: ubuntu-latest
    
    strategy:
      matrix:
        node-version: [18.x, 20.x]
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v3
      
      - name: Setup Node.js ${{ matrix.node-version }}
        uses: actions/setup-node@v3
        with:
          node-version: ${{ matrix.node-version }}
          cache: 'npm'
      
      - name: Install dependencies
        run: npm ci
      
      - name: Run Pact contract tests
        run: npm run test:pact
        env:
          CI: true
      
      - name: Upload Pact files as artifacts
        if: success()
        uses: actions/upload-artifact@v3
        with:
          name: pact-contracts-node-${{ matrix.node-version }}
          path: pacts/
          retention-days: 30
      
      - name: Upload test results
        if: always()
        uses: actions/upload-artifact@v3
        with:
          name: pact-test-results-node-${{ matrix.node-version }}
          path: |
            pact.log
            *.pact.log
          retention-days: 7
          if-no-files-found: ignore
  
  # Optional: Publish to Pact Broker
  publish-pacts:
    name: Publish Pacts to Broker
    runs-on: ubuntu-latest
    needs: pact-tests
    if: github.ref == 'refs/heads/main' || github.ref == 'refs/heads/develop'
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v3
      
      - name: Setup Node.js
        uses: actions/setup-node@v3
        with:
          node-version: '18.x'
      
      - name: Download Pact files
        uses: actions/download-artifact@v3
        with:
          name: pact-contracts-node-18.x
          path: pacts/
      
      - name: Install Pact CLI
        run: npm install -g @pact-foundation/pact-cli
      
      - name: Publish Pacts to Broker
        run: |
          pact-broker publish pacts/ \
            --consumer-app-version=${{ github.sha }} \
            --branch=${{ github.ref_name }} \
            --broker-base-url=${{ secrets.PACT_BROKER_URL }} \
            --broker-token=${{ secrets.PACT_BROKER_TOKEN }}
        env:
          PACT_BROKER_URL: ${{ secrets.PACT_BROKER_URL }}
          PACT_BROKER_TOKEN: ${{ secrets.PACT_BROKER_TOKEN }}
  
  # Optional: Verify contracts haven't broken
  verify-contracts:
    name: Verify Contract Compatibility
    runs-on: ubuntu-latest
    needs: pact-tests
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v3
      
      - name: Download Pact files
        uses: actions/download-artifact@v3
        with:
          name: pact-contracts-node-18.x
          path: pacts/
      
      - name: Compare with previous contracts
        run: |
          # Download previous pacts from main branch
          git fetch origin main
          git checkout origin/main -- pacts/ || echo "No previous pacts found"
          
          # Compare (this is a simple example - use pact-broker can-i-deploy in production)
          if [ -d "pacts/" ]; then
            echo "Comparing contracts..."
            diff -r pacts/ pacts-new/ || echo "Contracts have changed"
          fi
